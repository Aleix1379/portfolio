---
import Layout from '../layouts/Layout.astro'
import AboutSection from '../sections/AboutSection.tsx'
import ExperienceSection from '../sections/ExperienceSection.tsx'
import ProjectsSection from '../sections/ProjectsSection.tsx'
import ContactSection from '../sections/ContactSection.tsx'
---

<Layout
  title="Aleix - Web Developer Portfolio"
  description="Aleix's portfolio - Web developer specializing in Vue.js, React, and Node.js with experience in SOLID principles and Domain-Driven Design"
  image="/images/about.svg"
>
  <main class="main">
    <AboutSection client:visible />
    <ExperienceSection client:visible />
    <ProjectsSection client:visible />
    <ContactSection client:visible />
  </main>

  <style>
    .main {
      width: 100%;
      align-self: center;
      padding: 36px 20px 0;
    }

    @media (min-width: 768px) {
      .main {
        padding: 64px 24px 0;
      }
    }
  </style>
</Layout>
